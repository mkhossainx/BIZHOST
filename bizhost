    echo -e "  ${GRN}├────────────────────────────┤${R}"
    echo -e "  ${GRN}│${R} ${YLW}[5]${R} 📁 Open Site Folder      ${GRN}│${R}"
    echo -e "  ${GRN}│${R} ${YLW}[6]${R} 📂 Set Site Directory    ${GRN}│${R}"
