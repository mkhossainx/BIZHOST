mkdir -p "$PREFIX/tmp"

# в”Җв”Җв”Җв”Җв”Җ COLORS в”Җв”Җв”Җв”Җв”Җ
R='\e[0m'
BLD='\e[1m'
DIM='\e[2m'
RED='\e[1;31m'
GRN='\e[1;32m'
YLW='\e[1;33m'
CYN='\e[1;36m'
MAG='\e[1;35m'
WHT='\e[1;37m'
BLU='\e[1;34m'

# в”Җв”Җв”Җв”Җв”Җ LOAD CONFIG в”Җв”Җв”Җв”Җв”Җ
if [ -f "$CONFIG" ]; then
    source "$CONFIG"
fi

# Defaults if not set by config
SITE="${SITE:-/storage/emulated/0/BIZHOST}"
PORT="${PORT:-8080}"

# Save config helper
save_config() {
    echo "SITE=\"$SITE\"" > "$CONFIG"
    echo "PORT=$PORT" >> "$CONFIG"
}

# Init config if fresh
[ ! -f "$CONFIG" ] && save_config
mkdir -p "$SITE"

# в”Җв”Җв”Җв”Җв”Җ STATUS HELPERS в”Җв”Җв”Җв”Җв”Җ

is_server_running() {
    local pid
    [ -f "$PIDFILE" ] || return 1
    pid=$(cat "$PIDFILE" 2>/dev/null)
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

is_tunnel_running() {
    local pid
    [ -f "$TUNNEL_PID" ] || return 1
    pid=$(cat "$TUNNEL_PID" 2>/dev/null)
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

get_tunnel_url() {
    [ -f "$TUNNEL_URL_FILE" ] && cat "$TUNNEL_URL_FILE" || echo ""
}

srv_badge() {
    if is_server_running; then
        echo -e "${GRN}в—Ҹ RUNNING${R}"
    else
        echo -e "${RED}в—Ӣ STOPPED${R}"
    fi
}

tun_badge() {
    if is_tunnel_running; then
        local url; url=$(get_tunnel_url)
        if [ -n "$url" ]; then
            echo -e "${GRN}в—Ҹ ACTIVE${R} ${DIM}$url${R}"
        else
            echo -e "${YLW}в—Ң STARTING...${R}"
        fi
    else
        echo -e "${DIM}в—Ӣ OFF${R}"
    fi
}

