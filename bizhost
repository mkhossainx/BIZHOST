VERSION="2.0"
CONFIG="$PREFIX/tmp/bizhost.conf"
PIDFILE="$PREFIX/tmp/bizhost.pid"
WATCHDOG="$PREFIX/tmp/bizhost.watchdog"
TUNNEL_LOG="$PREFIX/tmp/bizhost.tunnel.log"
TUNNEL_PID="$PREFIX/tmp/bizhost.tunnel.pid"
TUNNEL_URL_FILE="$PREFIX/tmp/bizhost.tunnel.url"
