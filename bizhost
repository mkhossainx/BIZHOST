VERSION="2.2"
CONFIG="$PREFIX/tmp/bizhost.conf"
PIDFILE="$PREFIX/tmp/bizhost.pid"
WATCHDOG="$PREFIX/tmp/bizhost.watchdog"
TUNNEL_LOG="$PREFIX/tmp/bizhost.tunnel.log"
TUNNEL_PID="$PREFIX/tmp/bizhost.tunnel.pid"
TUNNEL_URL_FILE="$PREFIX/tmp/bizhost.url"
SERVER_LOG="$PREFIX/tmp/bizhost.server.log"

mkdir -p "$PREFIX/tmp"

# ─── COLORS ───
R='\e[0m'
BLD='\e[1m'
DIM='\e[2m'
RED='\e[1;31m'
GRN='\e[1;32m'
YLW='\e[1;33m'
CYN='\e[1;36m'
MAG='\e[1;35m'
WHT='\e[1;37m'

# ─── LOAD CONFIG ───
[ -f "$CONFIG" ] && source "$CONFIG"
SITE="${SITE:-/storage/emulated/0/BIZHOST}"
PORT="${PORT:-8080}"

save_config() {
    printf 'SITE="%s"\nPORT=%s\n' "$SITE" "$PORT" > "$CONFIG"
}

[ ! -f "$CONFIG" ] && save_config
mkdir -p "$SITE"

# ─── STATUS CHECKS ───
# Multi-method port check — no curl required
is_port_open() {
    local p=$1

    # Method 1: ss (iproute2 — standard in Termux)
    if command -v ss > /dev/null 2>&1; then
        ss -tlnp 2>/dev/null | grep -qE ":${p}( |$)" && return 0
    fi

    # Method 2: netstat fallback
    if command -v netstat > /dev/null 2>&1; then
        netstat -tlnp 2>/dev/null | grep -qE ":${p}( |$)" && return 0
    fi

    # Method 3: /proc/net/tcp — always present on Android/Linux
    # 127.0.0.1 in little-endian hex = 0100007F
    local hex_port
    hex_port=$(printf '%04X' "$p")
    if [ -f /proc/net/tcp ]; then
        grep -qi "0100007F:${hex_port}" /proc/net/tcp 2>/dev/null && return 0
        grep -qi "00000000:${hex_port}" /proc/net/tcp 2>/dev/null && return 0
    fi

    # Method 4: curl (last resort — may not be installed)
    if command -v curl > /dev/null 2>&1; then
        curl -sf --connect-timeout 1 --max-time 2 \
             "http://127.0.0.1:${p}/" > /dev/null 2>&1 && return 0
    fi

    return 1
}

is_server_running() {
    is_port_open "$PORT"
}

is_tunnel_running() {
    local pid
    [ -f "$TUNNEL_PID" ] || return 1
    pid=$(cat "$TUNNEL_PID" 2>/dev/null)
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

get_tunnel_url() {
    [ -f "$TUNNEL_URL_FILE" ] && cat "$TUNNEL_URL_FILE" || echo ""
}

srv_badge() {
    if is_server_running; then
        echo -e "${GRN}${BLD}● RUNNING${R}"
    else
        echo -e "${RED}○ STOPPED${R}"
    fi
}

tun_badge() {
    if is_tunnel_running; then
        local url; url=$(get_tunnel_url)
        if [ -n "$url" ]; then
            echo -e "${GRN}${BLD}● ACTIVE${R}"
        else
            echo -e "${YLW}◌ STARTING...${R}"
        fi
    else
        echo -e "${DIM}○ OFF${R}"
    fi
}

