VERSION="2.2"
CONFIG="$PREFIX/tmp/bizhost.conf"
PIDFILE="$PREFIX/tmp/bizhost.pid"
WATCHDOG="$PREFIX/tmp/bizhost.watchdog"
TUNNEL_LOG="$PREFIX/tmp/bizhost.tunnel.log"
TUNNEL_PID="$PREFIX/tmp/bizhost.tunnel.pid"
TUNNEL_URL_FILE="$PREFIX/tmp/bizhost.url"
SERVER_LOG="$PREFIX/tmp/bizhost.server.log"

mkdir -p "$PREFIX/tmp"

# в”Җв”Җв”Җ COLORS в”Җв”Җв”Җ
R='\e[0m'
BLD='\e[1m'
DIM='\e[2m'
RED='\e[1;31m'
GRN='\e[1;32m'
YLW='\e[1;33m'
CYN='\e[1;36m'
MAG='\e[1;35m'
WHT='\e[1;37m'

# в”Җв”Җв”Җ LOAD CONFIG в”Җв”Җв”Җ
[ -f "$CONFIG" ] && source "$CONFIG"
SITE="${SITE:-/storage/emulated/0/BIZHOST}"
PORT="${PORT:-8080}"

save_config() {
    printf 'SITE="%s"\nPORT=%s\n' "$SITE" "$PORT" > "$CONFIG"
}

[ ! -f "$CONFIG" ] && save_config
mkdir -p "$SITE"

# в”Җв”Җв”Җ STATUS CHECKS в”Җв”Җв”Җ
# Most reliable in Termux: check if PHP PID is alive
is_server_running() {
    [ -f "$PIDFILE" ] || return 1
    local pid
    pid=$(cat "$PIDFILE" 2>/dev/null)
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null
}

is_tunnel_running() {
    local pid
    [ -f "$TUNNEL_PID" ] || return 1
    pid=$(cat "$TUNNEL_PID" 2>/dev/null)
    [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

get_tunnel_url() {
    [ -f "$TUNNEL_URL_FILE" ] && cat "$TUNNEL_URL_FILE" || echo ""
}

srv_badge() {
    if is_server_running; then
        echo -e "${GRN}${BLD}в—Ҹ RUNNING${R}"
    else
        echo -e "${RED}в—Ӣ STOPPED${R}"
    fi
}

tun_badge() {
    if is_tunnel_running; then
        local url; url=$(get_tunnel_url)
        if [ -n "$url" ]; then
            echo -e "${GRN}${BLD}в—Ҹ ACTIVE${R}"
        else
            echo -e "${YLW}в—Ң STARTING...${R}"
        fi
    else
        echo -e "${DIM}в—Ӣ OFF${R}"
    fi
}

