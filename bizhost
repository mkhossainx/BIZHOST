    echo -e "${MAG}  в•‘     в„№  SYSTEM INFO        в•‘${R}"
    echo -e "${MAG}  в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј${R}"
