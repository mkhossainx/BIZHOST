# в”Җв”Җв”Җ UPDATE в”Җв”Җв”Җ
do_update() {
    clear
    echo -e "\n  ${CYN}[~] Fetching latest from GitHub...${R}\n"
    URL="https://raw.githubusercontent.com/bizft/BIZHOST/refs/heads/master/bizhost"
    TARGET="$PREFIX/bin/bizhost"
    TMP="$PREFIX/tmp/bizhost.new"

    curl -L --max-time 30 --progress-bar "$URL" -o "$TMP"
    if [ $? -eq 0 ] && [ -s "$TMP" ]; then
        mv "$TMP" "$TARGET"
        chmod +x "$TARGET"
        echo -e "\n  ${GRN}[вң”] Update complete!${R}"
        echo -e "  ${YLW}Restart bizhost to use new version.${R}"
    else
        rm -f "$TMP"
        echo -e "\n  ${RED}[вң—] Update failed. Check internet.${R}"
    fi
    sleep 3
}

