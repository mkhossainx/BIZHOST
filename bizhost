# ─── START SERVER ───
start_server() {
    echo ""
    if is_server_running; then
        echo -e "  ${YLW}[!] Server already running on :${PORT}${R}"
        sleep 1.5; return
    fi

    echo -e "  ${CYN}[~] Starting PHP server on port ${PORT}...${R}"

    # Clean up stale state
    pkill -f "php -S 127.0.0.1:$PORT" 2>/dev/null
    if [ -f "$WATCHDOG" ]; then
        kill "$(cat "$WATCHDOG")" 2>/dev/null
        rm -f "$WATCHDOG"
    fi
    rm -f "$PIDFILE"

    # Start watchdog + PHP in background
    (
        while true; do
            php -S "127.0.0.1:$PORT" -t "$SITE" >> "$SERVER_LOG" 2>&1 &
            PHP_PID=$!
            echo "$PHP_PID" > "$PIDFILE"
            wait "$PHP_PID"
            # Stop restarting if watchdog file was removed (manual stop)
            [ -f "$WATCHDOG" ] || break
            sleep 1
        done
    ) &
    WDOG_PID=$!
    echo "$WDOG_PID" > "$WATCHDOG"

    # Poll until port is open (max 15s) — no curl needed
    echo -ne "  ${DIM}Waiting for PHP"
    SUCCESS=0
    for i in $(seq 1 30); do
        sleep 0.5
        if is_port_open "$PORT"; then
            SUCCESS=1; break
        fi
        echo -ne "."
    done
    echo -e "${R}"

    if [ "$SUCCESS" -eq 1 ]; then
        echo -e "  ${GRN}╔═══════════════════════════╗${R}"
        echo -e "  ${GRN}║  ✓ Server Started!        ║${R}"
        echo -e "  ${GRN}╠═══════════════════════════╣${R}"
        echo -e "  ${GRN}║${R} Local: ${CYN}http://localhost:${PORT}${R}"
        echo -e "  ${GRN}║${R} Root : ${DIM}${SITE}${R}"
        echo -e "  ${GRN}╚═══════════════════════════╝${R}"
    else
        # Server didn't respond — cleanup and explain
        kill "$WDOG_PID" 2>/dev/null
        rm -f "$WATCHDOG"
        if [ -f "$PIDFILE" ]; then
            kill "$(cat "$PIDFILE")" 2>/dev/null
            rm -f "$PIDFILE"
        fi
        echo -e "  ${RED}╔═══════════════════════════╗${R}"
        echo -e "  ${RED}║  ✗ Server Failed to Start ║${R}"
        echo -e "  ${RED}╠═══════════════════════════╣${R}"
        echo -e "  ${RED}║${R} Possible causes:"
        echo -e "  ${RED}║${R} ${DIM}• php not installed${R}"
        echo -e "  ${RED}║${R} ${DIM}  → pkg install php${R}"
        echo -e "  ${RED}║${R} ${DIM}• Port $PORT in use${R}"
        echo -e "  ${RED}║${R} ${DIM}  → Use [7] to change port${R}"
        echo -e "  ${RED}║${R} ${DIM}• Site dir missing${R}"
        echo -e "  ${RED}╚═══════════════════════════╝${R}"
    fi
    sleep 3
}

# ─── CREATE TUNNEL ───
create_tunnel() {
    echo ""
    if ! is_server_running; then
        echo -e "  ${RED}[✗] Start the server first! → [1]${R}"
        sleep 2; return
    fi

    if is_tunnel_running; then
        echo -e "  ${YLW}[!] Tunnel already active:${R}"
        echo -e "  ${CYN}$(get_tunnel_url)${R}"
        sleep 2.5; return
    fi

    echo -e "  ${CYN}[~] Connecting Cloudflare tunnel...${R}"
    pkill cloudflared 2>/dev/null
    rm -f "$TUNNEL_LOG" "$TUNNEL_URL_FILE"

    cloudflared tunnel --url "http://127.0.0.1:$PORT" \
        > "$TUNNEL_LOG" 2>&1 &
    echo $! > "$TUNNEL_PID"

    echo -ne "  ${DIM}Connecting"
    LINK=""
    for i in $(seq 1 50); do
        LINK=$(grep -o \
            'https://[-a-zA-Z0-9.]*trycloudflare\.com' \
            "$TUNNEL_LOG" 2>/dev/null | head -1)
        [ -n "$LINK" ] && break
        echo -ne "."
        sleep 0.5
    done
    echo -e "${R}"

    if [ -n "$LINK" ]; then
        echo "$LINK" > "$TUNNEL_URL_FILE"
        echo -e "  ${GRN}╔═══════════════════════════╗${R}"
        echo -e "  ${GRN}║  🌐 TUNNEL ACTIVE!        ║${R}"
        echo -e "  ${GRN}╠═══════════════════════════╣${R}"
        echo -e "  ${GRN}║${R} ${WHT}Public URL:${R}"
        echo -e "  ${YLW}  $LINK${R}"
        echo -e "  ${GRN}╠═══════════════════════════╣${R}"
        echo -e "  ${GRN}║${R} ${DIM}Runs in background.${R}"
        echo -e "  ${GRN}║${R} ${DIM}Use [3] to stop.${R}"
        echo -e "  ${GRN}╚═══════════════════════════╝${R}"
    else
        echo -e "  ${RED}[✗] Tunnel failed. Check:${R}"
        echo -e "  ${DIM}  • Internet connection${R}"
        echo -e "  ${DIM}  • pkg install cloudflared${R}"
        kill "$(cat "$TUNNEL_PID")" 2>/dev/null
        rm -f "$TUNNEL_PID"
    fi
    sleep 3.5
}

# ─── STOP TUNNEL ───
stop_tunnel() {
    echo ""
    if is_tunnel_running; then
        kill "$(cat "$TUNNEL_PID")" 2>/dev/null
        pkill cloudflared 2>/dev/null
        rm -f "$TUNNEL_PID" "$TUNNEL_URL_FILE"
        echo -e "  ${GRN}[✔] Tunnel stopped.${R}"
    else
        echo -e "  ${YLW}[!] No tunnel is running.${R}"
    fi
    sleep 1.5
}

# ─── STOP SERVER ───
stop_server() {
    echo ""
    echo -e "  ${CYN}[~] Stopping...${R}"

    # Kill tunnel first
    if is_tunnel_running; then
        kill "$(cat "$TUNNEL_PID")" 2>/dev/null
        pkill cloudflared 2>/dev/null
        rm -f "$TUNNEL_PID" "$TUNNEL_URL_FILE"
    fi

    # Remove watchdog first — prevents auto-restart
    if [ -f "$WATCHDOG" ]; then
        kill "$(cat "$WATCHDOG")" 2>/dev/null
        rm -f "$WATCHDOG"
    fi

    # Kill PHP by stored PID
    if [ -f "$PIDFILE" ]; then
        kill "$(cat "$PIDFILE")" 2>/dev/null
        rm -f "$PIDFILE"
    fi

    # Final sweep on our specific port
    pkill -f "php -S 127.0.0.1:$PORT" 2>/dev/null
    sleep 1

    if is_server_running; then
        echo -e "  ${RED}[!] Server still responding on :${PORT}${R}"
        echo -e "  ${DIM}Try: pkill php${R}"
    else
        echo -e "  ${GRN}[✔] Server stopped.${R}"
    fi
    sleep 1.5
}

# ─── SET DIRECTORY ───
set_directory() {
    echo ""
    echo -e "  ${WHT}Current: ${DIM}$SITE${R}"
    echo -ne "  ${CYN}New path (ENTER = cancel): ${R}"
    read -r NEWDIR
    if [ -n "$NEWDIR" ]; then
        if mkdir -p "$NEWDIR" 2>/dev/null; then
            SITE="$NEWDIR"
            save_config
            echo -e "  ${GRN}[✔] Set to: $SITE${R}"
            echo -e "  ${YLW}[!] Restart server to apply.${R}"
        else
            echo -e "  ${RED}[✗] Cannot create path.${R}"
        fi
    else
        echo -e "  ${DIM}Cancelled.${R}"
    fi
    sleep 2.5
}

# ─── SET PORT ───
set_port() {
    echo ""
    echo -e "  ${WHT}Current port: ${CYN}$PORT${R}"
    echo -ne "  New port (1024-65535): "
    read -r NEWPORT
    if [[ "$NEWPORT" =~ ^[0-9]+$ ]] && \
       [ "$NEWPORT" -ge 1024 ] && [ "$NEWPORT" -le 65535 ]; then
        PORT=$NEWPORT
        save_config
        echo -e "  ${GRN}[✔] Port changed to $PORT${R}"
        echo -e "  ${YLW}[!] Restart server to apply.${R}"
    else
        echo -e "  ${RED}[✗] Invalid. Must be 1024–65535.${R}"
    fi
    sleep 2.5
}

# ─── VIEW LOGS ───
view_logs() {
    clear
    echo -e "${MAG}  ╔═══════════════════════════╗${R}"
    echo -e "${MAG}  ║  📋 SERVER LOGS (last 40)  ║${R}"
    echo -e "${MAG}  ╚═══════════════════════════╝${R}"
    echo ""
    if [ -f "$SERVER_LOG" ] && [ -s "$SERVER_LOG" ]; then
        tail -40 "$SERVER_LOG" | while IFS= read -r line; do
            if echo "$line" | grep -qi "error\|fatal"; then
                echo -e "  ${RED}$line${R}"
            elif echo "$line" | grep -qi " 200 \| 301 \| 304 "; then
                echo -e "  ${GRN}$line${R}"
            elif echo "$line" | grep -qi " 404 \| 403 \| 500 "; then
                echo -e "  ${YLW}$line${R}"
            else
                echo -e "  ${DIM}$line${R}"
            fi
        done
    else
        echo -e "  ${DIM}No logs yet. Start the server first.${R}"
    fi
    echo ""
    echo -ne "  ${DIM}Press ENTER to return... ${R}"
    read -r
}

# ─── SYSTEM INFO ───
show_info() {
    clear
    local php_ver cf_ver fc du_s
    php_ver=$(php -r 'echo PHP_VERSION;' 2>/dev/null || echo "Not installed")
    cf_ver=$(cloudflared --version 2>/dev/null | \
             grep -oP '\d+\.\d+\.\d+' | head -1 || echo "Not installed")
    fc=$(find "$SITE" -maxdepth 1 -type f 2>/dev/null | wc -l)
    du_s=$(du -sh "$SITE" 2>/dev/null | cut -f1 || echo "?")

    echo -e "${MAG}  ╔═══════════════════════════╗${R}"
    echo -e "${MAG}  ║     ℹ  SYSTEM INFO        ║${R}"
    echo -e "${MAG}  ╠═══════════════════════════╣${R}"
    echo -e "${MAG}  ║${R} BIZHOST  : ${CYN}v${VERSION}${R}"
    echo -e "${MAG}  ║${R} User     : ${WHT}$(whoami)${R}"
    echo -e "${MAG}  ║${R} PHP      : ${WHT}$php_ver${R}"
    echo -e "${MAG}  ║${R} CF       : ${WHT}$cf_ver${R}"
    echo -e "${MAG}  ╠═══════════════════════════╣${R}"
    echo -e "${MAG}  ║${R} Port     : ${YLW}$PORT${R}"
    echo -e "${MAG}  ║${R} Files    : ${DIM}$fc file(s) / $du_s${R}"
    echo -e "${MAG}  ║${R} Dir      : ${DIM}$SITE${R}"
    echo -e "${MAG}  ╠═══════════════════════════╣${R}"
    if is_server_running; then
        echo -e "${MAG}  ║${R} Server  : ${GRN}${BLD}RUNNING${R}"
    else
        echo -e "${MAG}  ║${R} Server  : ${RED}STOPPED${R}"
    fi
    if is_tunnel_running; then
        echo -e "${MAG}  ║${R} Tunnel  : ${GRN}${BLD}ACTIVE${R}"
        echo -e "${MAG}  ║${R} URL     : ${CYN}$(get_tunnel_url)${R}"
    else
        echo -e "${MAG}  ║${R} Tunnel  : ${DIM}OFF${R}"
    fi
    echo -e "${MAG}  ╚═══════════════════════════╝${R}"
    echo ""
    echo -ne "  ${DIM}Press ENTER to return... ${R}"
    read -r
}

# ─── UPDATE ───
do_update() {
    clear
    echo -e "\n  ${CYN}[~] Fetching latest from GitHub...${R}\n"
    URL="https://raw.githubusercontent.com/bizft/BIZHOST/refs/heads/master/bizhost"
    TARGET="$PREFIX/bin/bizhost"
    TMP="$PREFIX/tmp/bizhost.new"

    curl -L --max-time 30 --progress-bar "$URL" -o "$TMP"
    if [ $? -eq 0 ] && [ -s "$TMP" ]; then
        mv "$TMP" "$TARGET"
        chmod +x "$TARGET"
        echo -e "\n  ${GRN}[✔] Update complete!${R}"
        echo -e "  ${YLW}Restart bizhost to use new version.${R}"
    else
        rm -f "$TMP"
        echo -e "\n  ${RED}[✗] Update failed. Check internet.${R}"
    fi
    sleep 3
}

# ════════════════════════════
#           BOOT
# ════════════════════════════
clear
COLS=$(tput cols 2>/dev/null || echo 50)
if [ "$COLS" -lt 60 ]; then
    draw_compact_banner
else
    draw_banner
fi
echo -e "  ${MAG}━━━━━━━━━━━━━━━━━━━━━━━━━━${R}"
echo -e "  ${YLW}  ⚡ BIZ HOST v${VERSION} — BOOTING ⚡${R}"
echo -e "  ${MAG}━━━━━━━━━━━━━━━━━━━━━━━━━━${R}"
echo ""
echo -e "  ${DIM}Loading config...${R}"; sleep 0.3
echo -e "  ${DIM}Checking environment...${R}"; sleep 0.3
echo -e "  ${GRN}  Ready.${R}"; sleep 0.5

# ════════════════════════════
#         MAIN LOOP
# ════════════════════════════
while true; do
    draw_menu
    read -r opt

    case "$opt" in
        1) clear; start_server ;;
        2) clear; create_tunnel ;;
        3) clear; stop_tunnel ;;
        4) clear; stop_server ;;
        5) cd "$SITE" && bash ;;
        6) clear; set_directory ;;
        7) clear; set_port ;;
        8) view_logs ;;
        9) show_info ;;
        u|U) do_update ;;
        x|X)
            echo -e "\n  ${YLW}Goodbye — @bizft BIZ FACTORY${R}\n"
            sleep 0.6; exit 0
            ;;
        *)
            echo -e "  ${RED}[!] Invalid option.${R}"
            sleep 0.8
            ;;
    esac
done
