#!/data/data/com.termux/files/usr/bin/bash
# BIZHOST Installer v2.1 — @bizft BIZ FACTORY

# ─── COLORS ───
R='\e[0m'
BLD='\e[1m'
DIM='\e[2m'
RED='\e[1;31m'
GRN='\e[1;32m'
YLW='\e[1;33m'
CYN='\e[1;36m'
MAG='\e[1;35m'
WHT='\e[1;37m'

clear

# ─── BANNER ───
echo -e "${GRN}${BLD}"
echo "  ██████╗ ██╗███████╗"
echo "  ██╔══██╗██║╚══███╔╝"
echo -e "${CYN}${BLD}  ██████╔╝██║  ███╔╝ ${YLW}${BLD}██╗  ██╗ ██████╗ ███████╗████████╗"
echo -e "${CYN}${BLD}  ██╔══██╗██║ ███╔╝  ${YLW}${BLD}██║  ██║██╔═══██╗██╔════╝╚══██╔══╝"
echo -e "${MAG}${BLD}  ██████╔╝██║███████╗${YLW}${BLD}╚███████║╚██████╔╝███████║   ██║"
echo -e "${MAG}${BLD}  ╚═════╝ ╚═╝╚══════╝${YLW}${BLD} ╚══════╝ ╚═════╝ ╚══════╝   ╚═╝${R}"
echo ""
echo -e "${MAG}  ━━━━━━━━━━━━━━━━━━━━━━━━━━${R}"
echo -e "${YLW}${BLD}    ⚡ BIZHOST INSTALLER v2.1${R}"
echo -e "${GRN}       @bizft — BIZ FACTORY${R}"
echo -e "${MAG}  ━━━━━━━━━━━━━━━━━━━━━━━━━━${R}"
echo ""
sleep 0.5

# ─── PRE-FLIGHT ───
echo -e "${CYN}  [~] Pre-flight checks...${R}"
sleep 0.3

if [ -z "$PREFIX" ] || [ ! -d "$PREFIX" ]; then
    echo -e "${RED}  [✗] Termux not detected. Exiting.${R}"
    exit 1
fi
echo -e "${GRN}  [✔] Termux OK${R}"; sleep 0.2

if ! ping -c1 -W3 8.8.8.8 > /dev/null 2>&1; then
    echo -e "${RED}  [✗] No internet. Connect and retry.${R}"
    exit 1
fi
echo -e "${GRN}  [✔] Internet OK${R}"; sleep 0.2
echo ""

# ─── PACKAGES ───
echo -e "${CYN}  [~] Updating packages...${R}"
pkg update -y -q 2>/dev/null
echo -e "${GRN}  [✔] Done${R}"; sleep 0.2

echo -e "${CYN}  [~] Installing PHP...${R}"
pkg install php -y -q 2>/dev/null
if command -v php > /dev/null 2>&1; then
    PHP_VER=$(php -r 'echo PHP_VERSION;')
    echo -e "${GRN}  [✔] PHP ${PHP_VER}${R}"
else
    echo -e "${RED}  [✗] PHP install failed!${R}"; exit 1
fi
sleep 0.2

echo -e "${CYN}  [~] Installing cloudflared...${R}"
pkg install cloudflared -y -q 2>/dev/null
if ! command -v cloudflared > /dev/null 2>&1; then
    echo -e "${YLW}  [!] pkg failed — trying manual install...${R}"
    ARCH=$(uname -m)
    case "$ARCH" in
        aarch64) CF_BIN="cloudflared-linux-arm64" ;;
        armv7l)  CF_BIN="cloudflared-linux-arm" ;;
        x86_64)  CF_BIN="cloudflared-linux-amd64" ;;
        *) CF_BIN="" ;;
    esac
    if [ -n "$CF_BIN" ]; then
        CF_URL="https://github.com/cloudflare/cloudflared/releases/latest/download/${CF_BIN}"
        curl -L --max-time 60 --progress-bar "$CF_URL" \
             -o "$PREFIX/bin/cloudflared"
        chmod +x "$PREFIX/bin/cloudflared"
        echo -e "${GRN}  [✔] cloudflared installed manually${R}"
    else
        echo -e "${YLW}  [!] Unknown arch: $ARCH — skipping cloudflared${R}"
        echo -e "${DIM}      Tunneling unavailable. Server will still work.${R}"
    fi
else
    echo -e "${GRN}  [✔] cloudflared OK${R}"
fi
sleep 0.2
echo ""

# ─── STORAGE ───
echo -e "${YLW}  [!] Requesting storage permission...${R}"
echo -e "${DIM}      Please tap ALLOW if prompted!${R}"
sleep 1
termux-setup-storage
sleep 2
echo -e "${GRN}  [✔] Storage ready${R}"
echo ""

# ─── SITE DIRECTORY ───
SITE="/storage/emulated/0/BIZHOST"
mkdir -p "$SITE"
echo -e "${GRN}  [✔] Hosting dir: $SITE${R}"
sleep 0.2

# ─── DEFAULT INDEX.PHP ───
cat > "$SITE/index.php" << 'PHPEOF'
<?php $t = date('H:i:s'); $v = PHP_VERSION; ?>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>BIZHOST — Server Active</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#0a0a0f;color:#e0e0e0;font-family:'Courier New',monospace;
     display:flex;align-items:center;justify-content:center;min-height:100vh;
     padding:20px}
.card{border:1px solid #00ff9d;padding:32px 24px;max-width:420px;width:100%;
      text-align:center;box-shadow:0 0 40px #00ff9d1a}
.dot{display:inline-block;width:8px;height:8px;background:#00ff9d;
     border-radius:50%;margin-right:8px;animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.status{color:#00ff9d;font-size:12px;letter-spacing:4px;margin-bottom:16px}
h1{color:#fff;font-size:26px;font-weight:700;letter-spacing:2px}
.sub{color:#555;font-size:12px;margin:6px 0 24px}
.row{background:#111;border:1px solid #1a1a1a;padding:10px 14px;margin:6px 0;
     display:flex;justify-content:space-between;font-size:13px;text-align:left}
.row .k{color:#555}.row .v{color:#00ff9d}
.brand{margin-top:24px;color:#333;font-size:11px}
.brand a{color:#00ff9d;text-decoration:none}
</style>
</head>
<body>
<div class="card">
  <div class="status"><span class="dot"></span>SERVER ONLINE</div>
  <h1>BIZHOST</h1>
  <div class="sub">PHP Server is running</div>
  <div class="row"><span class="k">PHP</span><span class="v"><?=$v?></span></div>
  <div class="row"><span class="k">Host</span>
    <span class="v"><?=htmlspecialchars($_SERVER['HTTP_HOST']??'localhost')?></span></div>
  <div class="row"><span class="k">Time</span><span class="v"><?=$t?></span></div>
  <div class="row"><span class="k">Root</span>
    <span class="v"><?=htmlspecialchars($_SERVER['DOCUMENT_ROOT']??'—')?></span></div>
  <div class="brand">Powered by <a href="https://t.me/bizft">@bizft — BIZ FACTORY</a></div>
</div>
</body>
</html>
PHPEOF

echo -e "${GRN}  [✔] Default index.php created${R}"
sleep 0.2

# ─── INSTALL BINARY ───
echo -e "${CYN}  [~] Installing bizhost command...${R}"
if [ -f "bizhost" ]; then
    chmod +x bizhost
    cp bizhost "$PREFIX/bin/bizhost"
    echo -e "${GRN}  [✔] bizhost installed${R}"
else
    echo -e "${YLW}  [!] Local file not found — downloading...${R}"
    curl -L --max-time 30 \
         "https://raw.githubusercontent.com/bizft/BIZHOST/refs/heads/master/bizhost" \
         -o "$PREFIX/bin/bizhost"
    chmod +x "$PREFIX/bin/bizhost"
    echo -e "${GRN}  [✔] bizhost downloaded${R}"
fi
sleep 0.3
echo ""

# ─── DONE ───
echo -e "${GRN}${BLD}  ╔═══════════════════════════╗${R}"
echo -e "${GRN}${BLD}  ║  ✓ INSTALL COMPLETE!      ║${R}"
echo -e "${GRN}${BLD}  ╠═══════════════════════════╣${R}"
echo -e "${GRN}${BLD}  ║${R} Site : ${YLW}$SITE${R}"
echo -e "${GRN}${BLD}  ║${R} Run  : ${CYN}${BLD}bizhost${R}"
echo -e "${GRN}${BLD}  ║${R} By   : ${MAG}@bizft — BIZ FACTORY${R}"
echo -e "${GRN}${BLD}  ╚═══════════════════════════╝${R}"
echo ""
echo -e "  ${YLW}Type ${CYN}${BLD}bizhost${R}${YLW} to launch!${R}"
echo ""
